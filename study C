#include<stdio.h>
#define	N 3
   struct Student
	{
		int num;
		char name[20];
		float score[3];
		float aver;
	};

	int main()
	{
		void input(struct Student stu[]);
		struct Student max(struct Student stu[]);
		void print(struct Student stu);
		struct Student stu[N], * p = stu;
		input(p);
		print(max(p));
		return 0;
	}
	void input(struct Student stu[])
	{
		int i;
		printf("Please input every students'information: num,name,three scores:\n");
		for (i = 0;i < N;i++)
		{
			scanf_s(" %d %19s %f %f %f", &stu[i].num, stu[i].name,20, &stu[i].score[0], &stu[i].score[1], &stu[i].score[2]);
			stu[i].aver = (stu[i].score[0] + stu[i].score[1] + stu[i].score[2]) / 3.0;
			//name数组本身带地址无需&符号，在vs2026中在 VS 里，scanf_s 遇到 %s，必须这样写：
			//stu[i].name, 20
		    //也就是字符串数组后面要加一个大小。
		}
    }

	struct Student max(struct Student stu[])
	{
		int i, m = 0;
		for (i = 0;i < N;i++)
			if (stu[i].aver > stu[m].aver)
				m = i;
		return stu[m];
	}
	void print(struct Student stud)
	{
		printf("\nThe highest score student is : \n");
		printf("num:%d\nname:%s\nthree scores:%5.1f,%5.1f,%5.1f\naver:%6.2f\n",
			stud.num, stud.name, stud.score[0], stud.score[1], stud.score[2], stud.aver);
	}


建立动态链表
#include<stdio.h>
#include<stdlib.h>
#define LEN sizeof(struct Student)
struct Student
{
	long num;
	float score;
	struct Student* next;
};

int n;

struct Student* creat(void)
{
	struct Student* head;
	struct Student* p1, * p2;
	n = 0;
	p1 = p2 = (struct Student*)malloc(LEN);
	scanf_s("%ld %f", &p1->num, &p1->score);
	head = NULL;
	while (p1->num != 0)
	{
		n = n + 1;
		if (n == 1)
			head = p1;
		else p2->next = p1;
		p2 = p1;
		p1 = (struct Student*)malloc(LEN);
		scanf_s("%ld %f", &p1->num, &p1->score);
	}
	p2->next = NULL;
	return(head);
}
int main()
{
	struct Student* pt;
	pt = creat();
	printf("\nnum:%ld\nscore:%5.1f\n",pt->num, pt->score);
	return 0;
};



